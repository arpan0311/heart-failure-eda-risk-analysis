# -----------------------------------
# 1. Import Libraries
# -----------------------------------
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# -----------------------------------
# 2. Load Dataset
# -----------------------------------
df = pd.read_csv("../data/heart_failure_clinical_records_dataset.csv")

df.head()
# -----------------------------------
# 3. Data Overview
# -----------------------------------
df.info()
df.describe()
# -----------------------------------
# 4. Data Cleaning
# -----------------------------------
print("Missing values:\n", df.isnull().sum())
print("Duplicate values:", df.duplicated().sum())

# Insight:
# No significant missing values found, dataset is clean.
# -----------------------------------
# 5. Target Variable Analysis
# -----------------------------------
sns.countplot(x='DEATH_EVENT', data=df)
plt.title("Heart Failure Cases")
plt.show()

# Insight:
# Majority of patients survived, but a notable number experienced heart failure.

# -----------------------------------
# 6. Age Distribution
# -----------------------------------
sns.histplot(df['age'], kde=True)
plt.title("Age Distribution")
plt.show()

# Insight:
# Most patients are aged between 40–70.
# Higher age groups show increased risk.

# -----------------------------------
# 7. Age vs Heart Failure
# -----------------------------------
sns.boxplot(x='DEATH_EVENT', y='age', data=df)
plt.title("Age vs Heart Failure")
plt.show()

# Insight:
# Patients with heart failure tend to be older on average.

# -----------------------------------
# 8. Correlation Analysis
# -----------------------------------
plt.figure(figsize=(10,8))
sns.heatmap(df.corr(), annot=True, cmap='coolwarm')
plt.show()

# Insight:
# serum_creatinine and ejection_fraction show strong correlation with heart failure.

# -----------------------------------
# 9. Conclusion
# -----------------------------------

# Key Findings:
# - Age is a major risk factor
# - High serum creatinine increases risk
# - Low ejection fraction is strongly linked to heart failure

# This analysis helps identify high-risk patients early.
